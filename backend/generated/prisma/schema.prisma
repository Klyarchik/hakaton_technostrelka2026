generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model users {
  id           Int            @id @default(autoincrement())
  email        String         @unique @db.VarChar(255)
  password     String         @db.VarChar(255)
  nickname     String         @unique @db.VarChar(25)
  age_group    String         @db.VarChar(10)
  role         String         @db.VarChar(10)
  avatar       String
  created_at   DateTime       @default(now()) @db.Timestamptz(6)
  updated_at   DateTime       @default(now()) @db.Timestamptz(6)
  quests       quests[]
  team_members team_members[]
  teams        teams[]
}

model team_members {
  id        Int      @id @default(autoincrement())
  team_id   Int
  user_id   Int
  joined_at DateTime @default(now()) @db.Timestamptz(6)
  teams     teams    @relation(fields: [team_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users     users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([team_id, user_id])
}

model teams {
  id           Int            @id @default(autoincrement())
  name         String
  description  String?
  creator_id   Int
  invite_code  String         @unique
  created_at   DateTime       @default(now()) @db.Timestamptz(6)
  team_members team_members[]
  users        users          @relation(fields: [creator_id], references: [id], onUpdate: NoAction)
}

model quests {
  id               Int      @id @default(autoincrement())
  creator_id       Int
  title            String
  description      String
  location_text    String
  image            String
  difficulty       Int
  duration_minutes Int
  rules            String?
  status           String   @db.VarChar(20)
  is_hidden        Boolean? @default(false)
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)
  users            users    @relation(fields: [creator_id], references: [id], onUpdate: NoAction)
}
