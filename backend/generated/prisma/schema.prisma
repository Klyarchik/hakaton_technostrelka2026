generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model users {
  id           Int            @id @default(autoincrement())
  email        String         @unique @db.VarChar(255)
  password     String         @db.VarChar(255)
  nickname     String         @unique @db.VarChar(25)
  age_group    String         @db.VarChar(10)
  role         String         @db.VarChar(10)
  avatar       String
  created_at   DateTime       @default(now()) @db.Timestamptz(6)
  updated_at   DateTime       @default(now()) @db.Timestamptz(6)
  quests       quests[]
  sessions     sessions[]
  team_members team_members[]
  teams        teams[]
}

model team_members {
  id        Int      @id @default(autoincrement())
  team_id   Int
  user_id   Int
  joined_at DateTime @default(now()) @db.Timestamptz(6)
  teams     teams    @relation(fields: [team_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users     users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([team_id, user_id])
}

model teams {
  id           Int            @id @default(autoincrement())
  name         String
  description  String?
  creator_id   Int
  invite_code  String         @unique
  created_at   DateTime       @default(now()) @db.Timestamptz(6)
  sessions     sessions[]
  team_members team_members[]
  users        users          @relation(fields: [creator_id], references: [id], onUpdate: NoAction)
}

model quests {
  id                Int                 @id @default(autoincrement())
  creator_id        Int
  title             String
  description       String
  location_text     String
  image             String
  difficulty        Int
  duration_minutes  Int
  rules             String?
  status            String              @db.VarChar(20)
  is_hidden         Boolean?            @default(false)
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  updated_at        DateTime            @default(now()) @db.Timestamptz(6)
  rejection_reason  String?
  quest_checkpoints quest_checkpoints[]
  users             users               @relation(fields: [creator_id], references: [id], onUpdate: NoAction)
  sessions          sessions[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model quest_checkpoints {
  id               Int      @id @default(autoincrement())
  quest_id         Int
  order_index      Int
  title            String
  task_description String
  code_word        String
  latitude         Decimal  @db.Decimal(15, 10)
  longitude        Decimal  @db.Decimal(15, 10)
  hint             String?
  point_rules      String?
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)
  quests           quests   @relation(fields: [quest_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([quest_id, order_index])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model sessions {
  id                       Int       @id @default(autoincrement())
  quest_id                 Int
  user_id                  Int?
  team_id                  Int?
  status                   String    @default("started")
  transport_mode           String?
  started_at               DateTime  @default(now()) @db.Timestamptz(6)
  finished_at              DateTime? @db.Timestamptz(6)
  current_checkpoint_order Int?      @default(0)
  quests                   quests    @relation(fields: [quest_id], references: [id], onUpdate: NoAction)
  teams                    teams?    @relation(fields: [team_id], references: [id], onUpdate: NoAction)
  users                    users?    @relation(fields: [user_id], references: [id], onUpdate: NoAction)
}
